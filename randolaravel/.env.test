APP_NAME=randolaravel
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# Logs pour tests
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# # Base de données pour tests (SQLite - plus rapide)
# DB_CONNECTION=sqlite
# DB_HOST=
# DB_PORT=
# DB_DATABASE=:memory:
# DB_USERNAME=
# DB_PASSWORD=

MySQL pour les tests :
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rando_test
DB_USERNAME=rando_user
DB_PASSWORD=Root72

# Sessions pour tests
SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# Cache pour tests
CACHE_STORE=array
CACHE_PREFIX=test_cache

# Redis pour tests
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail pour tests (pas d'envoi réel)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="test@rando-ouest.com"
MAIL_FROM_NAME="${APP_NAME}"

# Queue pour tests
QUEUE_CONNECTION=sync

# JWT pour tests
JWT_SECRET=test_jwt_secret_for_github_actions_only
JWT_ALGO=HS256

# Variables React pour tests
REACT_APP_API_URL=http://localhost:8000/api