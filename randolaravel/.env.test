APP_NAME=randolaravel
APP_ENV=production
APP_KEY=${APP_KEY}
APP_DEBUG=false
APP_TIMEZONE=Europe/Paris
APP_URL=https://api.rando-ouest.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# Logs
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Base de données
DB_CONNECTION=mysql
DB_HOST=mysql_db
DB_PORT=3306
DB_DATABASE=rando_ouest
DB_USERNAME=rando_user
DB_PASSWORD=Root72

# Sessions
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# Cache
CACHE_STORE=database
CACHE_PREFIX=app_cache

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.rando-ouest.com
MAIL_PORT=587
MAIL_USERNAME=${MAIL_USERNAME}
MAIL_PASSWORD=${MAIL_PASSWORD}
MAIL_FROM_ADDRESS="support@rando-ouest.com"
MAIL_FROM_NAME="${APP_NAME}"

# JWT
JWT_SECRET=${JWT_SECRET}
JWT_ALGO=HS256
